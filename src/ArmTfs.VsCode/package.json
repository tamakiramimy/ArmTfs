{
  "name": "arm-tfs-vscode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "workspaceContains:**/.tf/workspace.json",
    "onView:armTfs.serverExplorer",
    "onView:armTfs.connections",
    "onView:armTfs.branches",
    "onView:armTfs.historyGraph",
    "onView:armTfs.merge",
    "onCommand:armTfs.configurePat",
    "onCommand:armTfs.configureCliCommand",
    "onCommand:armTfs.switchLanguage"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "armTfsHub",
          "title": "%viewContainer.tfs%",
          "icon": "media/tfs.svg"
        }
      ]
    },
    "views": {
      "armTfsHub": [
        {
          "id": "armTfs.connections",
          "name": "%view.connections%"
        },
        {
          "id": "armTfs.changes",
          "name": "%view.changes%"
        },
        {
          "id": "armTfs.serverExplorer",
          "name": "%view.serverExplorer%"
        },
        {
          "id": "armTfs.branches",
          "name": "%view.branches%"
        },
        {
          "id": "armTfs.historyGraph",
          "name": "%view.historyGraph%"
        },
        {
          "id": "armTfs.merge",
          "name": "%view.merge%"
        }
      ]
    },
    "commands": [
      {
        "command": "armTfs.configureCliCommand",
        "title": "%command.configureCli%",
        "category": "arm-tfs",
        "icon": "$(terminal)"
      },
      {
        "command": "armTfs.connections.add",
        "title": "%command.connectionsAdd%",
        "category": "arm-tfs",
        "icon": "$(add)"
      },
      {
        "command": "armTfs.connections.edit",
        "title": "%command.connectionsEdit%",
        "category": "arm-tfs",
        "icon": "$(edit)"
      },
      {
        "command": "armTfs.connections.delete",
        "title": "%command.connectionsDelete%",
        "category": "arm-tfs",
        "icon": "$(trash)"
      },
      {
        "command": "armTfs.connections.select",
        "title": "%command.connectionsSelect%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.configurePat",
        "title": "%command.configurePat%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showConfig",
        "title": "%command.showConfig%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.switchLanguage",
        "title": "%command.switchLanguage%",
        "category": "arm-tfs",
        "icon": "$(globe)"
      },
      {
        "command": "armTfs.createWorkspace",
        "title": "%command.createWorkspace%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.checkoutServerPathToFolder",
        "title": "%command.checkoutServerPathToFolder%",
        "category": "arm-tfs",
        "icon": "$(cloud-download)"
      },
      {
        "command": "armTfs.showWorkspace",
        "title": "%command.showWorkspace%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.addWorkspaceMapping",
        "title": "%command.addWorkspaceMapping%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.workspaceMappings.add",
        "title": "%command.workspaceMappingsAdd%",
        "category": "arm-tfs",
        "icon": "$(add)"
      },
      {
        "command": "armTfs.workspaceMappings.delete",
        "title": "%command.workspaceMappingsDelete%",
        "category": "arm-tfs",
        "icon": "$(trash)"
      },
      {
        "command": "armTfs.runGet",
        "title": "%command.runGet%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.checkout",
        "title": "%command.checkout%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.add",
        "title": "%command.add%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.undo",
        "title": "%command.undo%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.checkin",
        "title": "%command.checkin%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showStatus",
        "title": "%command.showStatus%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showHistory",
        "title": "%command.showHistory%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showDiff",
        "title": "%command.showDiff%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showBranch",
        "title": "%command.showBranch%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showChangeset",
        "title": "%command.showChangeset%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showLabel",
        "title": "%command.showLabel%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showMergeBase",
        "title": "%command.showMergeBase%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.showMergeCandidates",
        "title": "%command.showMergeCandidates%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.refreshScm",
        "title": "%command.refreshScm%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.changes.refresh",
        "title": "%command.changesRefresh%",
        "category": "arm-tfs",
        "icon": "$(refresh)"
      },
      {
        "command": "armTfs.changes.checkin",
        "title": "%command.changesCheckin%",
        "category": "arm-tfs",
        "icon": "$(check)"
      },
      {
        "command": "armTfs.changes.add",
        "title": "%command.changesAdd%",
        "category": "arm-tfs",
        "icon": "$(add)"
      },
      {
        "command": "armTfs.changes.checkout",
        "title": "%command.changesCheckout%",
        "category": "arm-tfs",
        "icon": "$(edit)"
      },
      {
        "command": "armTfs.changes.undo",
        "title": "%command.changesUndo%",
        "category": "arm-tfs",
        "icon": "$(discard)"
      },
      {
        "command": "armTfs.changes.openDiff",
        "title": "%command.changesOpenDiff%",
        "category": "arm-tfs",
        "icon": "$(diff)"
      },
      {
        "command": "armTfs.changes.openFile",
        "title": "%command.changesOpenFile%",
        "category": "arm-tfs",
        "icon": "$(go-to-file)"
      },
      {
        "command": "armTfs.changes.deleteUntracked",
        "title": "%command.changesDeleteUntracked%",
        "category": "arm-tfs",
        "icon": "$(trash)"
      },
      {
        "command": "armTfs.openResourceDiff",
        "title": "%command.openResourceDiff%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.checkoutResource",
        "title": "%command.checkoutResource%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.addResource",
        "title": "%command.addResource%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.undoResource",
        "title": "%command.undoResource%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.checkinFromScm",
        "title": "%command.checkinFromScm%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.sidebar.refresh",
        "title": "%command.sidebarRefresh%",
        "category": "arm-tfs",
        "icon": "$(refresh)"
      },
      {
        "command": "armTfs.serverExplorer.refresh",
        "title": "%command.serverExplorerRefresh%",
        "category": "arm-tfs",
        "icon": "$(refresh)"
      },
      {
        "command": "armTfs.serverExplorer.setFilter",
        "title": "%command.serverExplorerSetFilter%",
        "category": "arm-tfs",
        "icon": "$(filter)"
      },
      {
        "command": "armTfs.serverExplorer.clearFilter",
        "title": "%command.serverExplorerClearFilter%",
        "category": "arm-tfs",
        "icon": "$(filter-filled)"
      },
      {
        "command": "armTfs.serverExplorer.setRoot",
        "title": "%command.serverExplorerSetRoot%",
        "category": "arm-tfs",
        "icon": "$(root-folder)"
      },
      {
        "command": "armTfs.serverExplorer.getLatest",
        "title": "%command.serverExplorerGetLatest%",
        "category": "arm-tfs",
        "icon": "$(cloud-download)"
      },
      {
        "command": "armTfs.serverExplorer.checkout",
        "title": "%command.serverExplorerCheckout%",
        "category": "arm-tfs",
        "icon": "$(edit)"
      },
      {
        "command": "armTfs.serverExplorer.showHistory",
        "title": "%command.serverExplorerShowHistory%",
        "category": "arm-tfs",
        "icon": "$(history)"
      },
      {
        "command": "armTfs.serverExplorer.copyPath",
        "title": "%command.serverExplorerCopyPath%",
        "category": "arm-tfs",
        "icon": "$(copy)"
      },
      {
        "command": "armTfs.sidebar.setBranchScope",
        "title": "%command.sidebarSetBranchScope%",
        "category": "arm-tfs",
        "icon": "$(target)"
      },
      {
        "command": "armTfs.sidebar.setMergeSource",
        "title": "%command.sidebarSetMergeSource%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.sidebar.setMergeTarget",
        "title": "%command.sidebarSetMergeTarget%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.sidebar.copyTfvcPath",
        "title": "%command.sidebarCopyTfvcPath%",
        "category": "arm-tfs",
        "icon": "$(copy)"
      },
      {
        "command": "armTfs.sidebar.pullBranch",
        "title": "%command.sidebarPullBranch%",
        "category": "arm-tfs",
        "icon": "$(cloud-download)"
      },
      {
        "command": "armTfs.sidebar.checkoutBranch",
        "title": "%command.sidebarCheckoutBranch%",
        "category": "arm-tfs",
        "icon": "$(edit)"
      },
      {
        "command": "armTfs.sidebar.showBranchHistory",
        "title": "%command.sidebarShowBranchHistory%",
        "category": "arm-tfs",
        "icon": "$(history)"
      },
      {
        "command": "armTfs.sidebar.mergeFromBranch",
        "title": "%command.sidebarMergeFromBranch%",
        "category": "arm-tfs",
        "icon": "$(combine)"
      },
      {
        "command": "armTfs.sidebar.addBranch",
        "title": "%command.sidebarAddBranch%",
        "category": "arm-tfs",
        "icon": "$(git-branch-create)"
      },
      {
        "command": "armTfs.history.diffPrevious",
        "title": "%command.historyDiffPrevious%",
        "category": "arm-tfs",
        "icon": "$(diff)"
      },
      {
        "command": "armTfs.history.openBrowser",
        "title": "%command.historyOpenBrowser%",
        "category": "arm-tfs",
        "icon": "$(list-tree)"
      },
      {
        "command": "armTfs.history.selectForCompare",
        "title": "%command.historySelectCompare%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.history.compareSelected",
        "title": "%command.historyCompareSelected%",
        "category": "arm-tfs",
        "icon": "$(compare-changes)"
      },
      {
        "command": "armTfs.sidebar.swapMergePaths",
        "title": "%command.sidebarSwapMergePaths%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.sidebar.useMergeTarget",
        "title": "%command.sidebarUseMergeTarget%",
        "category": "arm-tfs"
      },
      {
        "command": "armTfs.sidebar.executeMergeCandidate",
        "title": "%command.sidebarExecuteMergeCandidate%",
        "category": "arm-tfs"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "armTfs.configureCliCommand",
          "when": "view == armTfs.connections",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.connections.add",
          "when": "view == armTfs.connections",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.workspaceMappings.add",
          "when": "view == armTfs.connections",
          "group": "navigation@3"
        },
        {
          "command": "armTfs.switchLanguage",
          "when": "view == armTfs.connections",
          "group": "navigation@4"
        },
        {
          "command": "armTfs.serverExplorer.refresh",
          "when": "view == armTfs.serverExplorer",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.serverExplorer.setFilter",
          "when": "view == armTfs.serverExplorer",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.serverExplorer.clearFilter",
          "when": "view == armTfs.serverExplorer",
          "group": "navigation@3"
        },
        {
          "command": "armTfs.changes.checkin",
          "when": "view == armTfs.changes",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.changes.refresh",
          "when": "view == armTfs.changes",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.serverExplorer.setRoot",
          "when": "view == armTfs.serverExplorer",
          "group": "navigation@4"
        },
        {
          "command": "armTfs.sidebar.refresh",
          "when": "view == armTfs.branches",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.sidebar.setBranchScope",
          "when": "view == armTfs.branches",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.sidebar.refresh",
          "when": "view == armTfs.historyGraph",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.history.openBrowser",
          "when": "view == armTfs.historyGraph",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.sidebar.refresh",
          "when": "view == armTfs.merge",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.sidebar.setMergeSource",
          "when": "view == armTfs.merge",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.sidebar.setMergeTarget",
          "when": "view == armTfs.merge",
          "group": "navigation@3"
        },
        {
          "command": "armTfs.sidebar.swapMergePaths",
          "when": "view == armTfs.merge",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "armTfs.changes.add",
          "when": "view == armTfs.changes && viewItem == armTfsChangeFile.untracked",
          "group": "inline@1"
        },
        {
          "command": "armTfs.changes.deleteUntracked",
          "when": "view == armTfs.changes && viewItem == armTfsChangeFile.untracked",
          "group": "inline@2"
        },
        {
          "command": "armTfs.changes.openFile",
          "when": "view == armTfs.changes && viewItem == armTfsChangeFile.untracked",
          "group": "inline@3"
        },
        {
          "command": "armTfs.changes.openDiff",
          "when": "view == armTfs.changes && viewItem =~ /armTfsChangeFile\\.(pending|localChanges|conflicts)/",
          "group": "inline@1"
        },
        {
          "command": "armTfs.changes.checkout",
          "when": "view == armTfs.changes && viewItem == armTfsChangeFile.localChanges",
          "group": "inline@2"
        },
        {
          "command": "armTfs.changes.add",
          "when": "view == armTfs.changes && viewItem == armTfsChangeFile.localChanges",
          "group": "inline@3"
        },
        {
          "command": "armTfs.changes.undo",
          "when": "view == armTfs.changes && viewItem =~ /armTfsChangeFile\\.(pending|conflicts)/",
          "group": "inline@2"
        },
        {
          "command": "armTfs.connections.edit",
          "when": "view == armTfs.connections && viewItem == armTfsConnectionProfile",
          "group": "inline@1"
        },
        {
          "command": "armTfs.connections.delete",
          "when": "view == armTfs.connections && viewItem == armTfsConnectionProfile",
          "group": "inline@2"
        },
        {
          "command": "armTfs.connections.select",
          "when": "view == armTfs.connections && viewItem == armTfsConnectionProfile",
          "group": "context@1"
        },
        {
          "command": "armTfs.workspaceMappings.delete",
          "when": "view == armTfs.connections && viewItem == armTfsWorkspaceMapping",
          "group": "inline@1"
        },
        {
          "command": "armTfs.serverExplorer.getLatest",
          "when": "view == armTfs.serverExplorer && viewItem =~ /armTfsServer(Folder|File)/",
          "group": "context@1"
        },
        {
          "command": "armTfs.serverExplorer.checkout",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFile",
          "group": "context@2"
        },
        {
          "command": "armTfs.serverExplorer.showHistory",
          "when": "view == armTfs.serverExplorer && viewItem =~ /armTfsServer(Folder|File)/",
          "group": "context@3"
        },
        {
          "command": "armTfs.serverExplorer.setRoot",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFolder",
          "group": "context@4"
        },
        {
          "command": "armTfs.serverExplorer.copyPath",
          "when": "view == armTfs.serverExplorer && viewItem =~ /armTfsServer(Folder|File)/",
          "group": "context@5"
        },
        {
          "command": "armTfs.checkoutServerPathToFolder",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFolder",
          "group": "context@6"
        },
        {
          "command": "armTfs.sidebar.mergeFromBranch",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFolder",
          "group": "context@7"
        },
        {
          "command": "armTfs.sidebar.addBranch",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFolder",
          "group": "context@8"
        },
        {
          "command": "armTfs.sidebar.pullBranch",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFolder",
          "group": "context@9"
        },
        {
          "command": "armTfs.sidebar.checkoutBranch",
          "when": "view == armTfs.serverExplorer && viewItem == armTfsServerFolder",
          "group": "context@10"
        },
        {
          "command": "armTfs.sidebar.pullBranch",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@1"
        },
        {
          "command": "armTfs.sidebar.checkoutBranch",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@2"
        },
        {
          "command": "armTfs.sidebar.copyTfvcPath",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@3"
        },
        {
          "command": "armTfs.sidebar.mergeFromBranch",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@4"
        },
        {
          "command": "armTfs.sidebar.addBranch",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@5"
        },
        {
          "command": "armTfs.sidebar.showBranchHistory",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@6"
        },
        {
          "command": "armTfs.checkoutServerPathToFolder",
          "when": "view == armTfs.branches && viewItem == armTfsSidebarBranch",
          "group": "context@7"
        },
        {
          "command": "armTfs.history.diffPrevious",
          "when": "view == armTfs.historyGraph && viewItem == armTfsSidebarChangeset",
          "group": "inline@1"
        },
        {
          "command": "armTfs.history.compareSelected",
          "when": "view == armTfs.historyGraph && viewItem == armTfsSidebarChangeset",
          "group": "inline@2"
        },
        {
          "command": "armTfs.history.selectForCompare",
          "when": "view == armTfs.historyGraph && viewItem == armTfsSidebarChangeset",
          "group": "context@1"
        },
        {
          "command": "armTfs.sidebar.useMergeTarget",
          "when": "view == armTfs.merge && viewItem == armTfsMergeTargetOption",
          "group": "context@1"
        },
        {
          "command": "armTfs.sidebar.copyTfvcPath",
          "when": "view == armTfs.merge && viewItem =~ /armTfs(MergeTargetOption|SidebarMergeCandidate)/",
          "group": "context@2"
        },
        {
          "command": "armTfs.sidebar.executeMergeCandidate",
          "when": "view == armTfs.merge && viewItem == armTfsSidebarMergeCandidate",
          "group": "context@3"
        }
      ],
      "scm/title": [
        {
          "command": "armTfs.refreshScm",
          "when": "scmProvider == armTfs",
          "group": "navigation@1"
        },
        {
          "command": "armTfs.runGet",
          "when": "scmProvider == armTfs",
          "group": "navigation@2"
        },
        {
          "command": "armTfs.checkinFromScm",
          "when": "scmProvider == armTfs",
          "group": "navigation@3"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "armTfs.openResourceDiff",
          "when": "scmProvider == armTfs",
          "group": "inline@1"
        },
        {
          "command": "armTfs.checkoutResource",
          "when": "scmProvider == armTfs && scmResourceState == armTfsModifiedNotCheckedOut",
          "group": "inline@2"
        },
        {
          "command": "armTfs.addResource",
          "when": "scmProvider == armTfs && scmResourceState == armTfsModifiedNotCheckedOut",
          "group": "inline@3"
        },
        {
          "command": "armTfs.addResource",
          "when": "scmProvider == armTfs && scmResourceState == armTfsUntracked",
          "group": "inline@1"
        },
        {
          "command": "armTfs.undoResource",
          "when": "scmProvider == armTfs && scmResourceState != armTfsModifiedNotCheckedOut && scmResourceState != armTfsUntracked",
          "group": "inline@4"
        },
        {
          "command": "armTfs.showHistory",
          "when": "scmProvider == armTfs && scmResourceState != armTfsUntracked",
          "group": "context@1"
        }
      ],
      "explorer/context": [
        {
          "command": "armTfs.checkout",
          "when": "resourceScheme == file",
          "group": "navigation@20"
        },
        {
          "command": "armTfs.add",
          "when": "resourceScheme == file",
          "group": "navigation@21"
        },
        {
          "command": "armTfs.undo",
          "when": "resourceScheme == file",
          "group": "navigation@22"
        },
        {
          "command": "armTfs.showDiff",
          "when": "resourceScheme == file",
          "group": "navigation@23"
        },
        {
          "command": "armTfs.showHistory",
          "when": "resourceScheme == file",
          "group": "navigation@24"
        }
      ],
      "editor/title/context": [
        {
          "command": "armTfs.checkout",
          "when": "resourceScheme == file",
          "group": "navigation@20"
        },
        {
          "command": "armTfs.showDiff",
          "when": "resourceScheme == file",
          "group": "navigation@21"
        },
        {
          "command": "armTfs.showHistory",
          "when": "resourceScheme == file",
          "group": "navigation@22"
        }
      ]
    },
    "configuration": {
      "title": "arm-tfs",
      "properties": {
        "armTfs.cli.command": {
          "type": "string",
          "default": "",
          "description": "Explicit CLI command to run. Leave empty to auto-discover a workspace build or fall back to arm-tfs on PATH."
        },
        "armTfs.serverExplorer.rootPath": {
          "type": "string",
          "default": "",
          "description": "Root TFVC server path shown in the Server Explorer tree (e.g. $/ or $/MyProject). Leave empty to prompt on first open."
        },
        "armTfs.cli.commandArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Arguments prepended before the arm-tfs subcommand. Example: [\"/path/to/arm-tfs.dll\"] when command is dotnet."
        },
        "armTfs.cli.cwd": {
          "type": "string",
          "default": "",
          "description": "Working directory for CLI execution. Leave empty to use the first workspace folder."
        },
        "armTfs.cli.preferWorkspaceBuild": {
          "type": "boolean",
          "default": true,
          "description": "Prefer a repo-local arm-tfs build before falling back to the arm-tfs command on PATH."
        },
        "armTfs.workspaceRoot": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to the real arm-tfs workspace root when the VS Code folder itself is not the TFVC workspace root."
        },
        "armTfs.tfsRootDirectory": {
          "type": "string",
          "default": "",
          "description": "Top-level local TFS root directory used to auto-compute branch checkout folders. Example: C:\\TFS maps $/C02_PTL_P090_BussinessCommon/Main to C:\\TFS\\C02_PTL_P090_BussinessCommon\\Main."
        },
        "armTfs.localRootDirectory": {
          "type": "string",
          "default": "",
          "description": "Deprecated alias for armTfs.tfsRootDirectory. Local root directory used to auto-compute where TFVC branches/folders are saved."
        },
        "armTfs.ui.language": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "zh-CN",
            "en"
          ],
          "description": "arm-tfs runtime UI language. 'auto' follows the VS Code display language."
        },
        "armTfs.autoCheckout.mode": {
          "type": "string",
          "default": "firstEdit",
          "enum": [
            "off",
            "firstEdit",
            "onSave"
          ],
          "description": "Automatically checkout tracked TFVC files when they are first edited or when they are saved."
        },
        "armTfs.autoCheckout.confirm": {
          "type": "boolean",
          "default": false,
          "description": "Prompt before automatic checkout is performed."
        },
        "armTfs.branch.scope": {
          "type": "string",
          "default": "",
          "description": "Optional TFVC server path used as the default branch tree scope. Leave empty to use the workspace mapping root."
        },
        "armTfs.history.top": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Number of changesets to load in the Changeset Graph view."
        },
        "armTfs.merge.sourcePath": {
          "type": "string",
          "default": "",
          "description": "Default TFVC source branch path shown in the Merge view."
        },
        "armTfs.merge.targetPath": {
          "type": "string",
          "default": "",
          "description": "Default TFVC target branch path shown in the Merge view."
        },
        "armTfs.merge.candidateTop": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Maximum number of merge candidates shown in the Merge view."
        },
        "armTfs.merge.candidateScan": {
          "type": "number",
          "default": 80,
          "minimum": 1,
          "description": "How many history entries to scan when computing merge candidates."
        },
        "armTfs.workspaceMappings": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "required": ["serverPath", "localPath"],
            "properties": {
              "serverPath": {
                "type": "string",
                "description": "TFVC server path (e.g. $/ or $/MyProject)"
              },
              "localPath": {
                "type": "string",
                "description": "Absolute local directory path (e.g. /Users/me/tfs or C:\\TFS)"
              }
            }
          },
          "description": "[Deprecated] Use the per-connection 'Workspace Mappings' UI instead. Each TFS connection profile now stores its own mappings. This setting is kept as a fallback when no profile is active."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.17.57",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  }
}
